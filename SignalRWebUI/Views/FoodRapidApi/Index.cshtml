@model List<ResultTastyApi>
@{
    ViewData["Title"] = "Tarifler";
    Layout = null;

    int pageSize = 12;
    int currentPage = Context.Request.Query.ContainsKey("page")
        ? int.Parse(Context.Request.Query["page"])
        : 1;
    int totalPages = (int)Math.Ceiling((double)Model.Count / pageSize);
    var pagedItems = Model.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
}
<!DOCTYPE html>
<html>
@await Component.InvokeAsync("_UILayoutHeadComponentPartial")
<body class="sub_page">
    @await Component.InvokeAsync("_MenuNavbarComponentPartial")

    <div class="container-fluid px-xl-5 py-4">

        <!-- Breadcrumb -->
        <nav class="mb-3" style="font-size:13px; color:#888;">
            <a href="/Default/Index" style="color:#888; text-decoration:none;">Ana Sayfa</a>
            <span class="mx-1">›</span>
            <a href="/Menu/Index" style="color:#888; text-decoration:none;">Api Listesi</a>
            <span class="mx-1">›</span>
            <span style="color:#333;">Tasty Api</span>
        </nav>

        <!-- Başlık -->
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
            <h4 class="mb-0" style="font-weight:500;">30 Dakika Altı Tarifler</h4>
            <span class="badge bg-light text-muted border" style="font-size:13px; font-weight:400;">
                @Model.Count tarif
            </span>
        </div>

        <!-- Kart Grid -->
        <div class="row g-4">
            @foreach (var item in pagedItems)
            {
                var time = item.total_time_minutes == 0 ? 15 : item.total_time_minutes;
                <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                    <div class="card h-100 border" style="border-radius:14px; overflow:hidden; transition: transform .15s, border-color .15s;">
                        <div style="aspect-ratio:4/3; overflow:hidden; background:#f5f5f5;">
                            <img src="@item.thumbnail_url"
                                 alt="@item.Name"
                                 style="width:100%; height:100%; object-fit:cover; display:block;"
                                 onerror="this.parentElement.style.background='#f0f0f0'" />
                        </div>
                        <div class="card-body p-4 d-flex flex-column gap-2">
                            <p class="mb-0" style="font-size:15px; font-weight:500; line-height:1.45;
                                   display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                                @item.Name
                            </p>
                            <div class="d-flex align-items-center gap-1 mt-auto" style="font-size:13px; color:#888;">
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                                    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5" />
                                    <path d="M8 5v3.5l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                                </svg>
                                @time dk
                            </div>
                        </div>
                        <div class="px-4 pb-4">
                            <a href="@item.original_video_url"
                               target="_blank"
                               class="btn btn-outline-dark btn-sm w-100"
                               style="font-size:13px; border-radius:8px; padding: 9px 0;">
                                Tarifi İzle →
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-center align-items-center gap-2 mt-5 mb-2">

                @* Önceki *@
                @if (currentPage > 1)
                {
                    <a href="?page=@(currentPage - 1)"
                       style="padding:8px 14px; border:0.5px solid #ddd; border-radius:8px; font-size:13px; color:#333; text-decoration:none; background:#fff;">
                        ← Önceki
                    </a>
                }

                @* Sayfa numaraları *@
                @for (int i = 1; i <= totalPages; i++)
                {
                    if (i == currentPage)
                    {
                        <span style="padding:8px 14px; border-radius:8px; font-size:13px; font-weight:500;
                                                 background:#222; color:#fff; border:0.5px solid #222;">
                            @i
                        </span>
                    }
                    else if (i == 1 || i == totalPages || (i >= currentPage - 2 && i <= currentPage + 2))
                    {
                        <a href="?page=@i"
                           style="padding:8px 14px; border:0.5px solid #ddd; border-radius:8px; font-size:13px; color:#333; text-decoration:none; background:#fff;">
                            @i
                        </a>
                    }
                    else if (i == currentPage - 3 || i == currentPage + 3)
                    {
                        <span style="font-size:13px; color:#aaa; padding: 0 4px;">…</span>
                    }
                }

                @* Sonraki *@
                @if (currentPage < totalPages)
                {
                    <a href="?page=@(currentPage + 1)"
                       style="padding:8px 14px; border:0.5px solid #ddd; border-radius:8px; font-size:13px; color:#333; text-decoration:none; background:#fff;">
                        Sonraki →
                    </a>
                }

            </div>

            <div class="text-center mb-4" style="font-size:12px; color:#aaa;">
                @((currentPage - 1) * pageSize + 1)–@(Math.Min(currentPage * pageSize, Model.Count)) / @Model.Count tarif gösteriliyor
            </div>
        }

    </div>

    @await Component.InvokeAsync("_UILayoutFooterComponentPartial")
    @await Component.InvokeAsync("_UILayoutScriptComponentPartial")
</body>
</html>