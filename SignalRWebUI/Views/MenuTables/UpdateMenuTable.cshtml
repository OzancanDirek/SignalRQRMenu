@model UpdateMenuTable
@{
    ViewData["Title"] = "UpdateMenuTable";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Masa İşlemleri</h4>
        <div class="row">
            <div class="col-md-12">
                <form method="post">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-header">
                                <div class="card-title">Masa Eklemek için Aşağıdaki Formu Doldurabilirsiniz.</div>
                            </div>
                            <div class="card-sub">
                                Masa ile ilgili işlemleri aşağıdan gerçekleştirebilirsiniz.
                            </div>
                        </div>
                        <div class="card-body">
                            <input type="hidden" asp-for="MenuTableID" />
                            <div class="form-group">
                                <label for="Name">Masa Adını giriniz</label>
                                <input asp-for="Name" type="text" class="form-control" id="name" placeholder="Yeni masa adını giriniz">
                            </div>
                        </div>
                        <div class="card-action">
                            <button type="submit" class="btn btn-secondary">Masa Bilgilerini Güncelle</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
