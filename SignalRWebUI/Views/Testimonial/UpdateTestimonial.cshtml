@model UpdateTestimonialDto
@{
    ViewData["Title"] = "UpdateTestimonial";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Referans İşlemleri</h4>
        <div class="row">
            <div class="col-md-12">
                <form method="post">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-header">
                                <div class="card-title">Yeni Referans Yorumu Eklemek için Aşağıdaki Formu Doldurabilirsiniz.</div>
                            </div>
                            <div class="card-sub">
                                Referans ile ilgili işlemleri aşağıdan gerçekleştirebilirsiniz.
                            </div>
                        </div>
                        <div class="card-body">
                            <input type="hidden" asp-for="TestimonialId" />
                            <div class="form-group">
                                <label for="Name">Müşteri Adını giriniz</label>
                                <input asp-for="Name" type="text" class="form-control" placeholder="Yorum için müşteri adını giriniz">
                            </div>

                            <div class="form-group">
                                <label for="Title">Müşteri Unvanını giriniz</label>
                                <input asp-for="Title" type="text" class="form-control" placeholder="Yorum için müşteri unvanını giriniz">
                            </div>

                            <div class="form-group">
                                <label for="ImageUrl">Müşteri Resim Dosya yolunu giriniz</label>
                                <input asp-for="ImageUrl" type="text" class="form-control" placeholder="Yorum için fotoğrafınızın dosya yolunu giriniz">
                            </div>

                            <div class="form-group">
                                <label for="Comment">Müşteri Yorumunu giriniz</label>
                                <input asp-for="Comment" type="text" class="form-control" placeholder="Düşüncelerinizi giriniz">
                            </div>

                        </div>
                        <button type="submit" class="btn btn-primary">
                            Yorumu Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

