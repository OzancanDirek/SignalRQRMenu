@model UpdateFeatureDto
@{
    ViewData["Title"] = "UpdateFeature";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Öne Çıkarılanlar İşlemleri</h4>
        <div class="row">
            <div class="col-md-12">
                <form method="post">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-header">
                                <div class="card-title">Yeni Öne Çıkarılan Eklemek için Aşağıdaki Formu Doldurabilirsiniz.</div>
                            </div>
                            <div class="card-sub">
                                Öne Çıkarılanlar ile ilgili işlemleri aşağıdan gerçekleştirebilirsiniz.
                            </div>
                        </div>
                        <input type="hidden" asp-for="FeatureId" />
                        <div class="card-body">
                            <div class="form-group">
                                <label for="Title1">1. Başlığı Giriniz</label>
                                <input asp-for="Title1" type="text" class="form-control" placeholder="İlk başlığı giriniz">
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="form-group">
                                <label for="Title2">2. Başlığı Giriniz</label>
                                <input asp-for="Title2" type="text" class="form-control" placeholder="İkinci başlığı giriniz">
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="form-group">
                                <label for="Title3">3. Başlığı Giriniz</label>
                                <input asp-for="Title3" type="text" class="form-control" placeholder="Üçüncü başlığı giriniz">
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="form-group">
                                <label for="Description1">1. Açıklamayı Giriniz</label>
                                <input asp-for="Description1" type="text" class="form-control" placeholder="Birinci başlığı giriniz">
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="form-group">
                                <label for="Description2">2. Açıklamayı Giriniz</label>
                                <input asp-for="Description2" type="text" class="form-control" placeholder="İkinci açıklamayı giriniz">
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="form-group">
                                <label for="Description3">3. Açıklamayı Giriniz</label>
                                <input asp-for="Description3" type="text" class="form-control" placeholder="Üçüncü başlığı giriniz">
                            </div>
                        </div>

                        <div class="card-action">
                            <button type="submit" class="btn btn-primary">Öne Çıkarılanı Güncelle</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

