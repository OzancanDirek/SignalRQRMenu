@model UserEditDto
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Profil İşlemleri</h4>
        <div class="row">
            <div class="col-md-12">
                <form method="post">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-header">
                                <div class="card-title">Profil Ayarlarınızı buradan yapınız</div>
                            </div>
                            <div class="card-sub">
                                Şifre ve Bilgi Güncelleme İşlemleri
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="form-group">
                                <label for="Name">Adınız</label>
                                <input type="text" class="form-control" asp-for="Name" id="Name" />
                            </div>
                            <div class="form-group">
                                <label for="Surname">Soyadınız</label>
                                <input type="text" class="form-control" asp-for="Surname" id="Surname" />
                            </div>
                            <div class="form-group">
                                <label for="Mail">Mail Adresiniz</label>
                                <input type="email" class="form-control" asp-for="Mail" id="Mail" />
                            </div>
                            <div class="form-group">
                                <label for="UserName">Kullanıcı Adınız</label>
                                <input type="text" class="form-control" asp-for="UserName" id="UserName" />
                            </div>
                            <div class="form-group">
                                <label for="Password">Şifreniz</label>
                                <input type="Password" class="form-control" asp-for="Password" id="Password" />
                            </div>
                            <div class="form-group">
                                <label for="ConfirmPassword">Şifre Tekrar</label>
                                <input type="Password" class="form-control" asp-for="ConfirmPassword" id="ConfirmPassword" />
                            </div>

                            <div class="card-action">
                                <button type="submit" class="btn btn-primary">Bilgileri Güncelle</button>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
