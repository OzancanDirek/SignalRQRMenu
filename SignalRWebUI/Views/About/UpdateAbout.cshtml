@model UpdateAboutDto
@{
    ViewData["Title"] = "UpdateAbout";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Hakkımızda İşlemleri</h4>
        <div class="row">
            <div class="col-md-12">
                <form method="post" asp-action="UpdateAbout" asp-controller="About">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title">Hakkımızda Alanını Güncellemek için Aşağıdaki Formu Doldurabilirsiniz</div>
                        </div>
                        <div class="card-sub">
                            Hakkımızda alanıyla ilgili işlemleri aşağıdan gerçekleştirebilirsiniz.
                        </div>
                        <div class="card-body">
                            <input type="hidden" asp-for="AboutId" />

                            <div class="form-group">
                                <label for="Title">Hakkımızda Başlığını giriniz</label>
                                <input asp-for="Title" type="text" class="form-control" placeholder="Yeni başlığı giriniz">
                            </div>

                            <div class="form-group">
                                <label for="ImageUrl">Hakkımızda Url'ini giriniz</label>
                                <input asp-for="ImageUrl" type="text" class="form-control" placeholder="Seçmiş olduğunuz görselin Url linkini giriniz">
                            </div>

                            <div class="card-body">
                                <div class="form-group">
                                    <label for="Description">Açıklamayı Giriniz</label>
                                    <textarea rows="5" class="form-control" asp-for="Description" id="Description"></textarea>
                                </div>
                            </div>

                        </div>
                        <div class="card-action">
                            <button type="submit" class="btn btn-outline-secondary">Hakkımızda Alanını Güncelle</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
