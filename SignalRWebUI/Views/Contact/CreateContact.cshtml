@model CreateContactDto
@{
    ViewData["Title"] = "CreateContact";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">İletişim İşlemleri</h4>
        <div class="row">
            <div class="col-md-12">
                <form method="post">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-header">
                                <div class="card-title">Yeni İletişim Alanı Eklemek için Aşağıdaki Formu Doldurabilirsiniz.</div>
                            </div>
                            <div class="card-sub">
                                İletişim alanıyla ilgili işlemleri aşağıdan gerçekleştirebilirsiniz.
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="form-group">
                                <label for="Title">Konum</label>
                                <input asp-for="Location" type="text" class="form-control" placeholder="Yeni konumu giriniz">
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="form-group">
                                <label for="ImageUrl">Telefon Numarası</label>
                                <input asp-for="Phone" type="text" class="form-control" placeholder="Telefon numarası bilginizi giriniz">
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="form-group">
                                <label for="Description">Mail</label>
                                <input asp-for="Mail" type="text" class="form-control" placeholder="Mail bilginizi giriniz">
                            </div>

                            <div class="card-body">
                                <div class="form-group">
                                    <label for="ImageUrl">Alt Başlık</label>
                                    <input asp-for="FooterTitle" type="text" class="form-control" placeholder="Alt Başlık giriniz">
                                </div>
                            </div>

                            <div class="card-body">
                                <div class="form-group">
                                    <label for="Description">Açık Günler</label>
                                    <input asp-for="OpenDays" type="text" class="form-control" placeholder="Açık Günlerin bilgisini giriniz">
                                </div>
                            </div>

                            <div class="card-body">
                                <div class="form-group">
                                    <label for="Description">Açık Günler Açıklaması</label>
                                    <input asp-for="OpenDaysDescription" type="text" class="form-control" placeholder="Açık Günlerin Açıklama bilgisini giriniz">
                                </div>
                            </div>

                            <div class="card-body">
                                <div class="form-group">
                                    <label for="Description">Açık Saatler</label>
                                    <input asp-for="OpenHours" type="text" class="form-control" placeholder="Açık Saatlerin bilgisini giriniz">
                                </div>
                            </div>

                            <div class="card-body">
                                <div class="form-group">
                                    <label for="Description">Alt Açıklama Alanı</label>
                                    <input asp-for="FooterDescription" type="text" class="form-control" placeholder="Alt Başlık Açıklama bilgisini giriniz">
                                </div>
                            </div>

                            <div class="card-action">
                                <button type="submit" class="btn btn-primary">İletişim Alanı Ekle</button>
                            </div>
                        </div>
                </form>
            </div>
        </div>
    </div>
</div>

