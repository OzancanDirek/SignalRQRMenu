@model SignalRWebUI.Dtos.CategoryDtos.UpdateCategoryDto
@{
    ViewData["Title"] = "UpdateCategory";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Kategori İşlemleri</h4>
        <div class="row">
            <div class="col-md-12">
                <form method="post">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title">Kategoriyi Güncellemek için Aşağıdaki Formu Doldurabilirsiniz.</div>
                        </div>
                        <div class="card-sub">
                            Kategori ile ilgili işlemleri aşağıdan gerçekleştirebilirsiniz.
                        </div>
                        <div class="card-body">
                            <input type="hidden" asp-for="CategoryId" />
                            <div class="form-group">
                                <label for="categoryName">Kategori Adını giriniz</label>
                                <input asp-for="CategoryName" type="text" class="form-control" placeholder="Yeni kategori adını giriniz">
                            </div>
                        </div>
                        <div class="card-action">
                            <button type="submit" class="btn btn-outline-secondary">Kategoriyi Güncelle</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

